{
  "name": "tiangong-ai-decks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run clean && tsc -b",
    "check": "tsc -b --pretty",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; const paths = ['apps/cli/dist','packages/domain/dist','packages/pipeline/dist']; for (const path of paths) rmSync(path, { recursive: true, force: true });\"",
    "cli": "tsx --no-cache apps/cli/src/index.ts",
    "dev": "tsx --no-cache apps/cli/src/index.ts",
    "lint": "eslint . --max-warnings=0",
    "verify": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
